# Development (mode=development). Override with .env.local if needed.
# Required: API base URL (all API calls and image origin). No default in code.
VITE_APP_BASE_URL=http://localhost:3000/api
# Optional: CSP img-src origins (if unset, derived from VITE_APP_BASE_URL).
VITE_CSP_IMG_SRC=http://localhost:3000

VITE_APP_API_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
VITE_USE_COOKIE_AUTH=false
