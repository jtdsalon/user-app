# Copy to .env or .env.local and set values.
# API and image URLs come from env only (no default in code). Restart dev server after changes.
# Vite loads: .env → .env.[mode] → .env.local (later overrides).

# Required: API base URL (all API calls and image server origin).
VITE_APP_BASE_URL=http://localhost:3000/api
# Examples:
# VITE_APP_BASE_URL=https://your-api-dev.example.com/api
# VITE_APP_BASE_URL=/api

# Optional: space-separated origins for CSP img-src. If unset, derived from VITE_APP_BASE_URL.
# VITE_CSP_IMG_SRC=http://localhost:3000 http://127.0.0.1:3000
# VITE_CSP_IMG_SRC=https://salon-development.s3.amazonaws.com

VITE_APP_API_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
VITE_USE_COOKIE_AUTH=false
